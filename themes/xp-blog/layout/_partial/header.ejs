<!-- 顶部导航窗口 -->
<div class="window nav-window">
  <div class="title-bar">
    <div class="title-bar-text">
      <img src="<%= url_for('/images/Internet-Shortcut.png') %>" alt="" width="16" height="16" draggable="false">
    </div>
    <div class="title-bar-controls">
      <button aria-label="Minimize"></button>
      <button aria-label="Maximize"></button>
      <button aria-label="Close"></button>
    </div>
  </div>
  <div class="window-body nav-body">
    <% if (theme.nav) { %>
      <% for (const [label, url] of Object.entries(theme.nav)) { %>
        <a href="<%= url_for(url) %>">
          <button class="<%= (page.path === url || (url === '/' && is_home())) ? 'focused' : '' %>"><%= label %></button>
        </a>
      <% } %>
    <% } %>
  </div>
</div>
