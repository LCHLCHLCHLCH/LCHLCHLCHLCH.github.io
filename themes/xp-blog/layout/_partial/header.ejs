<!-- XP 任务栏导航（严格参照 winXP Footer 结构） -->
<div class="xp-taskbar">
  <div class="taskbar-left">
    <a href="<%= url_for('/') %>"><img src="<%= url_for('/images/start.png') %>" alt="Start" class="taskbar-start" draggable="false"></a>
    <% if (theme.nav) { %>
      <% for (const [label, url] of Object.entries(theme.nav)) { %>
        <a href="<%= url_for(url) %>" class="taskbar-btn<%= (url_for(page.path) === url_for(url) || (url === '/' && is_home())) ? ' focus' : ' cover' %>"><%= label %></a>
      <% } %>
    <% } %>
  </div>
  <div class="taskbar-right">
    <span class="taskbar-time" id="taskbarTime"></span>
  </div>
</div>
