<!DOCTYPE html>
<html lang="<%= config.language %>">
<head>
  <%- partial('_partial/head') %>
</head>
<body>
  <!-- Bliss 壁纸背景 -->
  <div class="desktop-bg"></div>

  <!-- 顶部任务栏（紧贴边缘） -->
  <%- partial('_partial/header') %>

  <!-- 桌面容器：多窗口布局 -->
  <div class="desktop-container">

    <!-- 三栏布局 -->
    <div class="desktop-columns">

      <!-- 左侧栏 -->
      <% if (!page.nosidebar) { %>
      <aside class="sidebar-left">
        <%- partial('_partial/sidebar-left') %>
      </aside>
      <% } %>

      <!-- 中间：主内容区 -->
      <main class="content-main<% if (page.nosidebar) { %> full<% } %>">
        <%- body %>
      </main>

      <!-- 右侧栏 -->
      <% if (!page.nosidebar) { %>
      <aside class="sidebar-right">
        <%- partial('_partial/sidebar-right') %>
      </aside>
      <% } %>

    </div>

    <!-- 底部状态栏 -->
    <%- partial('_partial/footer') %>
  </div>
</body>
<script>
(function() {
  var el = document.getElementById('taskbarTime');
  if (!el) return;
  function tick() {
    var d = new Date();
    var h = d.getHours();
    var m = d.getMinutes();
    var ap = h >= 12 ? 'PM' : 'AM';
    if (h > 12) h -= 12;
    if (h === 0) h = 12;
    el.textContent = h + ':' + (m < 10 ? '0' : '') + m + ' ' + ap;
  }
  tick();
  setInterval(tick, 1000);
})();
(function() {
  var toc = document.querySelector('.toc-window');
  if (!toc) return;
  var rect = toc.getBoundingClientRect();
  var origTop = rect.top + window.scrollY;
  var origRight = window.innerWidth - rect.right;
  var origWidth = rect.offsetWidth;
  function onScroll() {
    if (window.scrollY > origTop - 40) {
      toc.style.position = 'fixed';
      toc.style.top = '40px';
      toc.style.right = origRight + 'px';
      toc.style.width = origWidth + 'px';
      toc.style.zIndex = '10';
    } else {
      toc.style.position = '';
      toc.style.top = '';
      toc.style.right = '';
      toc.style.width = '';
      toc.style.zIndex = '';
    }
  }
  window.addEventListener('scroll', onScroll);
  window.addEventListener('resize', function() {
    if (toc.style.position === 'fixed') {
      toc.style.position = '';
      var r = toc.getBoundingClientRect();
      origTop = r.top + window.scrollY;
      origRight = window.innerWidth - r.right;
      origWidth = r.width;
      onScroll();
    } else {
      var r = toc.getBoundingClientRect();
      origTop = r.top + window.scrollY;
      origRight = window.innerWidth - r.right;
      origWidth = r.width;
    }
  });
})();
</script>
</html>
