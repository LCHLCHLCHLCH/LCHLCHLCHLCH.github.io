<!-- 桌面小部件式 —— 三窗并排 -->
<div class="widgets-row">
  <!-- 左窗：作者 -->
  <div class="window widget-window widget-author">
    <div class="title-bar">
      <div class="title-bar-text">
        <img src="<%= url_for('/images/information.png') %>" alt="" width="16" height="16" draggable="false"> 关于
      </div>
      <div class="title-bar-controls">
        <button aria-label="Minimize"></button>
        <button aria-label="Maximize"></button>
        <button aria-label="Close"></button>
      </div>
    </div>
    <div class="window-body widget-body">
      <div class="author-avatar">
        <img src="<%= url_for('/images/avatar.jpg') %>" alt="avatar" onerror="this.style.display='none'">
      </div>
      <div class="author-name"><%= theme.author ? theme.author.name : config.author %></div>
      <div class="author-stats">
        <div class="stat-item">
          <span class="stat-num"><%= site.posts.length %></span>
          <span class="stat-label">文章</span>
        </div>
        <div class="stat-item">
          <span class="stat-num"><%= site.tags.length %></span>
          <span class="stat-label">标签</span>
        </div>
        <div class="stat-item">
          <span class="stat-num"><%= site.categories.length %></span>
          <span class="stat-label">分类</span>
        </div>
      </div>
      <% if (theme.author && theme.author.motto) { %>
      <div class="author-motto">« <%= theme.author.motto %> »</div>
      <% } %>
    </div>
  </div>

  <!-- 中窗：欢迎 -->
  <div class="window widget-window widget-welcome">
    <div class="title-bar">
      <div class="title-bar-text">
        <img src="<%= url_for('/images/information.png') %>" alt="" width="16" height="16" draggable="false"> 欢迎
      </div>
      <div class="title-bar-controls">
        <button aria-label="Minimize"></button>
        <button aria-label="Maximize"></button>
        <button aria-label="Close"></button>
      </div>
    </div>
    <div class="window-body widget-body widget-welcome-body">
      <div class="welcome-hero">
        <div class="welcome-title"><%= config.title %></div>
        <% if (config.subtitle) { %><div class="welcome-subtitle"><%= config.subtitle %></div><% } %>
        <% if (config.description) { %><p class="welcome-desc"><%= config.description %></p><% } %>
      </div>
      <div class="welcome-nav">
        <a href="<%= url_for('/archives/') %>"><button>📂 归档</button></a>
        <a href="<%= url_for('/tags/') %>"><button>🏷️ 标签</button></a>
        <a href="<%= url_for('/about/') %>"><button>ℹ️ 关于</button></a>
      </div>
    </div>
  </div>

  <!-- 右窗：最新动态 -->
  <div class="window widget-window widget-posts">
    <div class="title-bar">
      <div class="title-bar-text">
        <img src="<%= url_for('/images/XML.png') %>" alt="" width="16" height="16" draggable="false"> 最新文章
      </div>
      <div class="title-bar-controls">
        <button aria-label="Minimize"></button>
        <button aria-label="Maximize"></button>
        <button aria-label="Close"></button>
      </div>
    </div>
    <div class="window-body widget-body">
      <ul class="latest-list">
        <% site.posts.sort('date', -1).limit(6).each(function(post) { %>
          <li>
            <span class="latest-date"><%= date(post.date, 'MM-DD') %></span>
            <a href="<%= url_for(post.path) %>"><%= post.title %></a>
          </li>
        <% }) %>
      </ul>
    </div>
  </div>
</div>
