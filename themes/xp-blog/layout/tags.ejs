<!-- 标签列表页 -->
<div class="window article-window">
  <div class="title-bar">
    <div class="title-bar-text">
      <img src="<%= url_for('/images/XML.png') %>" alt="" width="16" height="16" draggable="false"> 所有标签
    </div>
    <div class="title-bar-controls">
      <button aria-label="Minimize"></button>
      <button aria-label="Maximize"></button>
      <button aria-label="Close"></button>
    </div>
  </div>
  <div class="window-body tags-body">
    <div class="tags-header">
      <h2>标签</h2>
      <p><%= site.tags.length %> 个标签</p>
    </div>
    <div class="tags-grid">
      <% site.tags.each(function(tag) { %>
        <a href="<%= url_for(tag.path) %>" class="tags-btn"><%= tag.name %> <span><%= tag.posts.length %></span></a>
      <% }) %>
    </div>
  </div>
</div>
