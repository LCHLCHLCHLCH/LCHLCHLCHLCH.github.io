<!-- 文章列表窗口 -->
<div class="window article-window">
  <div class="title-bar">
    <div class="title-bar-text">
      <img src="<%= url_for('/images/fax-cover-page.png') %>" alt="" width="16" height="16" draggable="false"> 博文
    </div>
    <div class="title-bar-controls">
      <button aria-label="Minimize"></button>
      <button aria-label="Maximize"></button>
      <button aria-label="Close"></button>
    </div>
  </div>
  <div class="window-body">

    <!-- 文章列表 -->
    <div class="post-list">
      <% page.posts.each(function(post) { %>
        <%- partial('_partial/post-card', { post: post }) %>
      <% }) %>
    </div>

    <!-- 分页 -->
    <% if (page.total > 1) { %>
    <div class="pagination">
      <% if (page.prev) { %>
        <a href="<%= url_for(page.prev_link) %>"><button>← 上一页</button></a>
      <% } %>
      <span class="page-info"><%= page.current %> / <%= page.total %></span>
      <% if (page.next) { %>
        <a href="<%= url_for(page.next_link) %>"><button>下一页 →</button></a>
      <% } %>
    </div>
    <% } %>

    <!-- 没有文章时 -->
    <% if (page.posts.length === 0) { %>
    <div class="post-empty">
      <p>暂无文章。</p>
    </div>
    <% } %>

  </div>
</div>
